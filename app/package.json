{
  "name": "mise-android",
  "version": "1.0.0",
  "private": true,
  "description": "Mise — iOS + Android app. Capacitor shell around the Mise web app; the web files in the repo root are the single source of truth.",
  "scripts": {
    "sync": "node scripts/sync-web.js && cap sync",
    "sync:android": "node scripts/sync-web.js && cap sync android",
    "sync:ios": "node scripts/sync-web.js && cap sync ios",
    "open": "cap open android",
    "open:android": "cap open android",
    "open:ios": "cap open ios",
    "run:android": "cap run android",
    "run:ios": "cap run ios"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.2",
    "@capacitor/app": "^8.1.1",
    "@capacitor/browser": "^8.0.4",
    "@capacitor/cli": "^8.4.2",
    "@capacitor/core": "^8.4.2",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/ios": "^8.4.2",
    "@capacitor/share": "^8.0.1",
    "@revenuecat/purchases-capacitor": "^13.2.3"
  }
}
